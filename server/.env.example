# Copy to .env and fill in real values. .env is gitignored.

# ─ Required ─────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/id3a?retryWrites=true&w=majority

# Single OpenRouter key fans out to Gemini Pro, Nano Banana 2, Veo 3.1, Lyria 3, Gemini TTS.
OPENROUTER_API_KEY=sk-or-v1-<your-openrouter-key>

# 32+ random bytes for signing JWT cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<random-hex-string>

# Resend account for magic-link sign-in + "your video is ready" emails.
RESEND_API_KEY=re_<your-resend-key>

# ─ Optional ─────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# Public-facing client URL — used in email + share links.
# Dev: http://localhost:5173. Prod: https://your.domain
APP_URL=http://localhost:5173

# Sender address. Use a domain you've verified in Resend, or leave the default
# for test mode (only delivers to the verified account email).
EMAIL_FROM=onboarding@resend.dev

# VPS storage paths for shared MP4s, posters, and temp render workdirs.
# Defaults are fine for local dev; override in production for persistence.
SHARES_DIR=/var/lib/id3a/shares
POSTERS_DIR=/var/lib/id3a/posters
RENDERS_TEMP_DIR=/tmp/id3a/renders
